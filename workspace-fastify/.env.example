# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=3101
LOG_LEVEL=info

# API
REQUEST_TIMEOUT_MS=30000

# Rate limiting
TRUST_PROXY=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_TIME_WINDOW_MS=60000
RATE_LIMIT_CHAT_STREAM_MAX=20
RATE_LIMIT_CHAT_MAX=30
RATE_LIMIT_RETRIEVAL_MAX=60
RATE_LIMIT_FEEDBACK_MAX=120
RATE_LIMIT_ADMIN_MAX=120
RATE_LIMIT_CONVERSATION_MAX=120
RATE_LIMIT_DEFAULT_MAX=300
RATE_LIMIT_CACHE_SIZE=10000
RATE_LIMIT_EVENT_LOG_SIZE=500
RATE_LIMIT_ALLOW_LIST=

# Retrieval scope policy
RETRIEVAL_SCOPE_DEFAULT=all
RETRIEVAL_TOP_K=5

# LLM / Embedding
OPENAI_API_KEY=
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GOOGLE_EMBEDDING_MODEL=gemini-embedding-2-preview
GOOGLE_EMBEDDING_OUTPUT_DIM=768
EMBEDDING_MODEL_AUTO_ALIGN=true
EMBEDDING_MODEL_RESOLVE_TTL_MS=300000
PGVECTOR_SEARCH_ENABLED=true
GOOGLE_EMBEDDING_MIN_INTERVAL_MS=700
GOOGLE_EMBEDDING_MAX_RETRIES=8
LLM_TIMEOUT_MS=5000
LLM_CANDIDATE_TOP_N=3
LLM_MAX_OUTPUT_TOKENS=256
LLM_SKIP_ON_HIGH_CONFIDENCE=true
LLM_SKIP_MIN_CONFIDENCE=0.75
LLM_TWO_STEP_MAX_CONFIDENCE=0.55
LLM_ANSWER_CACHE_TTL_MS=30000
QUERY_EMBEDDING_CACHE_TTL_MS=300000
RETRIEVAL_CACHE_TTL_MS=30000
EMBEDDING_FAILURE_COOLDOWN_MS=300000
LLM_PROVIDER=google
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# Source DB (MariaDB) - SCC source of truth
SOURCE_DB_HOST=
SOURCE_DB_PORT=3306
SOURCE_DB_NAME=
SOURCE_DB_USER=
SOURCE_DB_PASSWORD=
SOURCE_DB_SSL=false

# Vector DB (PostgreSQL + pgvector)
VECTOR_DB_HOST=
VECTOR_DB_PORT=5432
VECTOR_DB_NAME=
VECTOR_DB_USER=
VECTOR_DB_PASSWORD=
VECTOR_DB_SCHEMA=ai_core
VECTOR_DB_TABLE=scc_embeddings
VECTOR_DB_SSL=false

# Ingest/backfill
INGEST_BACKFILL_ON_BOOT=true
INGEST_INTERVAL_SEC=300
INGEST_BATCH_SIZE=100
INGEST_MAX_RETRY=3

# Manual scope filtering hints (optional)
TENANT_ID=
PRODUCT_VERSION=

# Migration bridge (legacy reference endpoint)
LEGACY_BASE_URL=http://localhost:3004
