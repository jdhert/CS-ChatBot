# Google API Keys
GOOGLE_API_KEY=your_google_api_key_here

# Vector Database (PostgreSQL + pgvector)
VECTOR_DB_HOST=DB_HOST_REMOVED
VECTOR_DB_PORT=5432
VECTOR_DB_NAME=ai2
VECTOR_DB_USER=novian
VECTOR_DB_PASSWORD=REMOVED

# Vector Search Settings
PGVECTOR_SEARCH_ENABLED=true
EMBEDDING_MODEL_AUTO_ALIGN=true

# LLM Settings
LLM_PROVIDER=google
GOOGLE_MODEL=gemini-2.5-flash
LLM_TIMEOUT_MS=7000
LLM_SKIP_ON_HIGH_CONFIDENCE=false
LLM_CANDIDATE_TOP_N=5

# Embedding Settings
EMBEDDING_PROVIDER=google
GOOGLE_EMBEDDING_MODEL=gemini-embedding-2-preview
GOOGLE_EMBEDDING_OUTPUT_DIM=768
EMBEDDING_MODEL_AUTO_ALIGN=true
EMBEDDING_MODEL_RESOLVE_TTL_MS=300000
QUERY_EMBEDDING_CACHE_TTL_MS=300000
EMBEDDING_FAILURE_COOLDOWN_MS=300000
GOOGLE_EMBEDDING_MIN_INTERVAL_MS=100
GOOGLE_EMBEDDING_MAX_RETRIES=3
EMBEDDING_COVERAGE_CACHE_TTL_MS=60000
EMBEDDING_COVERAGE_HEALTH_TIMEOUT_MS=1500
EMBEDDING_COVERAGE_WARN_MIN_PCT=99
EMBEDDING_COVERAGE_CRITICAL_MIN_PCT=95
EMBEDDING_COVERAGE_WARN_PENDING_CHUNKS=500
EMBEDDING_COVERAGE_CRITICAL_PENDING_CHUNKS=2000

# User manual MVP
MANUAL_RETRIEVAL_ENABLED=true
MANUAL_DOWNLOAD_ENABLED=false
MANUAL_PREVIEW_ENABLED=false
MANUAL_PREVIEW_DIR=/app/manuals/preview
MANUAL_PDF_DIR=/app/manuals/pdf
MANUAL_PREVIEW_REQUIRE_MANIFEST=true
MANUAL_PREVIEW_MATCH_MIN_SCORE=0.30
MANUAL_PREVIEW_MANIFEST_PATH=/app/manuals/preview/manifest.json
MANUAL_PREVIEW_TMP_DIR=/tmp/manual-preview
MANUAL_PREVIEW_REPORT_PATH=/app/docs/eval/manual_preview_coverage.latest.json
MANUAL_PREVIEW_MIN_SCORE=0.12
MANUAL_PREVIEW_DPI=120
MANUAL_SOURCE_DIR=/app/manuals/user
MANUAL_CANDIDATE_TOP_K=5
MANUAL_HOWTO_PRIORITY_ENABLED=true
MANUAL_PRIORITY_MIN_SCORE=0.75
MANUAL_FALLBACK_MIN_SCORE=0.75
MANUAL_PRIORITY_MIN_LEXICAL_COVERAGE=0.12
MANUAL_EMBEDDING_BATCH_SIZE=50
MANUAL_EMBEDDING_MAX_BATCHES=4
MANUAL_CHUNK_CHARS=950

# Node Environment
NODE_ENV=production

# Build / deploy metadata (normally injected by GitHub Actions during deploy)
APP_COMMIT_SHA=unknown
APP_BUILD_TIME=
APP_BUILD_REF=main
APP_GITHUB_RUN_ID=
APP_GITHUB_REPOSITORY=jdhert/CS-ChatBot
APP_IMAGE_TAG=latest

# Rate limiting
TRUST_PROXY=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_TIME_WINDOW_MS=60000
RATE_LIMIT_CHAT_STREAM_MAX=20
RATE_LIMIT_CHAT_MAX=30
RATE_LIMIT_RETRIEVAL_MAX=60
RATE_LIMIT_FEEDBACK_MAX=120
RATE_LIMIT_ADMIN_MAX=120
RATE_LIMIT_CONVERSATION_MAX=120
RATE_LIMIT_DEFAULT_MAX=300
RATE_LIMIT_CACHE_SIZE=10000
RATE_LIMIT_EVENT_LOG_SIZE=500
RATE_LIMIT_ALLOW_LIST=
